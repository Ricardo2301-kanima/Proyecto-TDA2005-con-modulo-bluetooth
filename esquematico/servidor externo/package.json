{
  "name": "esp32-audio-streamer",
  "version": "1.0.0",
  "description": "Real-time audio streaming server for ESP32 devices via HTTP/MP3",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2:start": "pm2 start server.js --name esp32-streamer",
    "pm2:stop": "pm2 stop esp32-streamer",
    "pm2:restart": "pm2 restart esp32-streamer",
    "pm2:logs": "pm2 logs esp32-streamer"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["esp32", "audio", "streaming", "yt-dlp", "ffmpeg", "mp3", "iot"],
  "license": "MIT"
}